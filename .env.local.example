# Public base URL of the deployed dashboard, e.g. https://your-dashboard.vercel.app
# Used in workflows and any client code that needs to call the API from outside.
NEXT_PUBLIC_BASE_URL=https://your-dashboard.example.com

# Google Service Account JSON (single-line stringified). Get this from
# the JSON key file you download from Google Cloud Console.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet ID — the long string between /d/ and /edit in the Sheet URL.
SHEET_ID=

# Google Drive folder ID for the proof drops embed.
DRIVE_FOLDER_ID=

# Shared secret for the Amex inbound-email webhook. Configure your
# inbound-email provider (CloudMailin / Postmark / Resend) to include
# `Authorization: Bearer <secret>` on POSTs to /api/amex/inbound.
# Generate with `openssl rand -hex 32`.
AMEX_INGEST_SECRET=
